# ── Python ────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# ── Virtual environments ──────────────────────────
venv/
.venv/
env/
ENV/
.env.bak

# ── Environment & Secrets ─────────────────────────
# NEVER commit real API keys — copy .env.example to .env and fill in values
.env
!.env.example

# ── Data — vector store and uploaded files ────────
# These are generated at runtime and can be large
data/chroma_db/
data/uploads/
# Keep the data folder itself (for the metadata JSON)
!data/.gitkeep

# ── Logs ──────────────────────────────────────────
*.log
logs/

# ── IDE / Editor ──────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing ───────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.xml

# ── Build / Distribution ──────────────────────────
dist/
build/
*.egg-info/
.eggs/

# ── Jupyter ───────────────────────────────────────
.ipynb_checkpoints/

# ── Type checking ─────────────────────────────────
.mypy_cache/
.ruff_cache/

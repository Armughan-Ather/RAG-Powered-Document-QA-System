# ─────────────────────────────────────────────
#  Intelligent Document Analysis System — ENV
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_NAME="Intelligent Document Analysis System"
APP_VERSION="1.0.0"
ENV=development          # development | staging | production
DEBUG=False

# ── API ──────────────────────────────────────
API_V1_PREFIX=/api/v1

# ── Security ─────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── OpenAI ───────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.0

# ── Embeddings (HuggingFace — runs locally) ──
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu     # cpu | cuda

# ── Reranker (HuggingFace cross-encoder — runs locally) ──
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=3         # chunks kept after reranking

# ── Chunking ─────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# ── Retrieval ────────────────────────────────
RETRIEVAL_K=10           # initial candidates fetched from vector store
RETRIEVAL_TOP_K=5        # final chunks passed to LLM after MMR
MMR_LAMBDA=0.5           # 0 = max diversity, 1 = max relevance

# ── Chroma Vector Store ───────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=documents

# ── File Upload ───────────────────────────────
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=[".pdf",".txt",".docx"]
UPLOAD_DIR=./data/uploads
